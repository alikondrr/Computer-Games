<Window x:Class="ComputerGames.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование каталога" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список игр в каталоге" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Таблица игр -->
        <DataGrid x:Name="gamesGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120"/>
                <DataGridTextColumn Header="Возраст" Binding="{Binding AgeRestriction}" Width="80"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding QualityRating}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель добавления -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Добавить данные игры через запятую:" Grid.Row="0" Grid.Column="0" 
                           VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="newGameTitle" Grid.Row="0" Grid.Column="1" Margin="5" 
                          ToolTip="Формат: тип, название, жанр, возраст, рейтинг&#x0a;Пример: single, Stardew Valley, Simulation, 6, 9.1"/>
                <Button x:Name="addBtn" Grid.Row="0" Grid.Column="2" Content="Добавить" 
                        Width="100" Margin="5" Click="AddGame_Click"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Удалить выбранное:" 
                           VerticalAlignment="Center" Margin="5"/>
                <Button x:Name="removeBtn" Grid.Row="1" Grid.Column="2" Content="Удалить" 
                        Width="100" Margin="5" Click="RemoveGame_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
