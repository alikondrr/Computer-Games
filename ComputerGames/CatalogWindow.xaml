<Window x:Class="ComputerGames.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование каталога" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список игр в каталоге" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Таблица игр -->
        <DataGrid x:Name="gamesGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120"/>
                <DataGridTextColumn Header="Режим" Binding="{Binding GameMode}" Width="100"/>
                <DataGridTextColumn Header="Платформы" Binding="{Binding Platforms}" Width="100"/>
                <DataGridTextColumn Header="Возраст" Binding="{Binding AgeRestriction}" Width="80"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding QualityRating}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель добавления -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Строка: Название, жанр, возраст, рейтинг через запятую -->
                <TextBlock Text="Данные игры (Название, Жанр, Возраст, Рейтинг):" 
                           Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="newGameTitle" Grid.Row="0" Grid.Column="1" Margin="5" 
                         ToolTip="Пример: The Witcher 3, RPG, 18, 9.5"/>

                <!-- Строка: Выбор типа игры (режим) -->
                <TextBlock Text="Тип игры (режим):" Grid.Row="1" Grid.Column="0" 
                           VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="gameTypeCombo" Grid.Row="1" Grid.Column="1" Margin="5" 
                          SelectedIndex="0">
                    <ComboBoxItem Content="SingleGame (PC + Console)"/>
                    <ComboBoxItem Content="MultiplayerGame (PC + Console + Mobile)"/>
                    <ComboBoxItem Content="OnlineGame (PC + Mobile)"/>
                </ComboBox>

                <!-- Кнопки -->
                <Button x:Name="addBtn" Grid.Row="2" Grid.Column="1" Content="Добавить" 
                        Width="100" Margin="5" HorizontalAlignment="Right" Click="AddGame_Click"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Удалить выбранное:" 
                           VerticalAlignment="Center" Margin="5"/>
                <Button x:Name="removeBtn" Grid.Row="2" Grid.Column="1" Content="Удалить" 
                        Width="100" Margin="5" HorizontalAlignment="Left" Click="RemoveGame_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
