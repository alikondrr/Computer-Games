<Window x:Class="ComputerGames.GameInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация об игре" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <TextBlock Grid.Row="1" Text="Название:" FontWeight="Bold"/>
        <TextBlock x:Name="titleText" Grid.Row="2"/>

        <TextBlock Grid.Row="3" Text="Жанр:" FontWeight="Bold"/>
        <TextBlock x:Name="genreText" Grid.Row="4"/>

        <TextBlock Grid.Row="5" Text="Возрастной рейтинг:" FontWeight="Bold"/>
        <TextBlock x:Name="ageText" Grid.Row="6"/>

        <TextBlock Grid.Row="7" Text="Дата выхода:" FontWeight="Bold"/>
        <TextBlock x:Name="dateText" Grid.Row="8"/>

        <TextBlock Grid.Row="9" Text="Рейтинг качества:" FontWeight="Bold"/>
        <TextBlock x:Name="ratingText" Grid.Row="9" Margin="0,18,0,2"/>

        <Button Grid.Row="9" Content="Закрыть" Width="100" HorizontalAlignment="Center" Click="Close_Click" Margin="0,70,0,-70"/>
    </Grid>
</Window>