<Window x:Class="ComputerGames.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ComputerGames - Поиск игр" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="44.156"/>
            <RowDefinition Height="39.795"/>
            <RowDefinition Height="Auto" MinHeight="31.96"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Каталог компьютерных игр" 
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,6" Grid.Column="1" Width="326"/>

        <!-- Выбор игры -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Выберите игру:" VerticalAlignment="Center" Margin="5,0,5,0" Height="16"/>
        <ComboBox x:Name="gamesCombo" Grid.Row="2" Grid.Column="1" Margin="5,5,5,5" DisplayMemberPath="Title"/>
        <Button x:Name="showGameBtn" Grid.Row="2" Grid.Column="2" Content="Показать данные" Margin="5,5,5,5" Click="ShowGame_Click" IsEnabled="False"/>

        <!-- Фильтр по платформе -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Платформа:" VerticalAlignment="Center" Margin="5,0,5,0" Height="16"/>
        <ComboBox x:Name="platformCombo" Grid.Row="3" Grid.Column="1" Margin="5,5,5,5" SelectionChanged="Filter_Changed">
            <ComboBoxItem Content="Все"/>
            <ComboBoxItem Content="PC"/>
            <ComboBoxItem Content="console"/>
            <ComboBoxItem Content="mobile"/>
        </ComboBox>

        <!-- Фильтр по режиму -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Режим игры:" VerticalAlignment="Center" Margin="5,0,5,0" Height="16"/>
        <ComboBox x:Name="modeCombo" Grid.Row="4" Grid.Column="1" Margin="5,5,5,5" SelectionChanged="Filter_Changed">
            <ComboBoxItem Content="Все"/>
            <ComboBoxItem Content="single"/>
            <ComboBoxItem Content="multi"/>
            <ComboBoxItem Content="online"/>
        </ComboBox>

        <!-- Формат сохранения -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Формат:" VerticalAlignment="Center" Margin="5,0,5,0" Height="16"/>
        <ComboBox x:Name="formatCombo" Grid.Row="5" Grid.Column="1" Margin="5,5,5,5" SelectionChanged="Format_Changed">
            <ComboBoxItem Content="JSON"/>
            <ComboBoxItem Content="XML"/>
        </ComboBox>

        <!-- Кнопка каталога -->
        <Button x:Name="openCatalogBtn" Grid.Column="1" Content="Открыть каталог" Margin="100,5,99,5" Click="OpenCatalog_Click" Grid.Row="1"/>

        <!-- Статус -->
        <TextBlock x:Name="statusText" Grid.Row="7" Grid.ColumnSpan="3" 
                   Text="Готов" Margin="5,5,5,5" Foreground="Gray"/>
    </Grid>
</Window>